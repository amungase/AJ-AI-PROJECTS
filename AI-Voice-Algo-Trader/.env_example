# Copy to .env and fill in values. Never commit .env to git.

# --- Telegram (from @BotFather) ---
TELEGRAM_BOT_TOKEN=<your telegram token>

# Your numeric Telegram user id (only this user can use the bot).
# Message @userinfobot on Telegram to get your id.
TELEGRAM_ALLOWED_USER_ID=<your telegram user id>


#GEMINI_API_KEY=<your gemini key>

# --- Zerodha Kite Connect (https://developers.kite.trade/) ---
KITE_API_KEY=<your kite key>
KITE_API_SECRET=<your kite secret>

# Daily access token — run: python kite_login.py
KITE_ACCESS_TOKEN=<your kite token>

# --- Safety ---
# true = log orders but do not send to exchange
DRY_RUN=false

# --- Optional: voice transcription ---
# Path to ffmpeg binary if not on PATH (required for voice notes)
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
